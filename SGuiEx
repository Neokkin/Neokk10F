local function setupHoldButton(button, actionCallback)
    local isHolding = false
    button.MouseButton1Down:Connect(function()
        isHolding = true
        actionCallback()
        task.wait(0.7)
        while isHolding do
            actionCallback()
            task.wait(0.04)
        end
    end)
    button.InputEnded:Connect(function(inputObj)
        if inputObj.UserInputType == Enum.UserInputType.MouseButton1 or inputObj.UserInputType == Enum.UserInputType.Touch then
            isHolding = false
        end
    end)
end

