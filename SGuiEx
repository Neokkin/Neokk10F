-- // --- [SECTION: ADVANCED MULTI-LINE COMPILER ENGINE] ---
local function snap(value, step) if step == 0 then return value end return math.round(value / step) * step end

local function getTargetCFrame()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return CFrame.new() end
    local root = player.Character.HumanoidRootPart
    local baseCFrame = root.CFrame * CFrame.new(0, 0, -20)
    if currentState.yLockEnabled then baseCFrame = CFrame.new(baseCFrame.X, currentState.lockedYValue, baseCFrame.Z) * baseCFrame.Rotation else currentState.lockedYValue = baseCFrame.Y end
    local finalX = snap(currentState.posX, currentState.snapGrid)
    local finalY = snap(currentState.posY, currentState.snapGrid)
    local finalZ = snap(currentState.posZ, currentState.snapGrid)
    local finalRotX = snap(currentState.rotX, currentState.snapAngle)
    local finalRotY = snap(currentState.rotY, currentState.snapAngle)
    local finalRotZ = snap(currentState.rotZ, currentState.snapAngle)
    return baseCFrame * CFrame.new(finalX, finalY, finalZ) * CFrame.Angles(math.rad(finalRotX), math.rad(finalRotY), math.rad(finalRotZ))
end

local function getEquationCFrames()
    local cframes = {}
    local totalObjects = math.max(1, currentState.multi)
    local baseCF = getTargetCFrame()
    local equationsList = string.split(currentState.equationText, "\n")
    
    for _, rawEquation in ipairs(equationsList) do
        local line = string.lower(string.gsub(rawEquation, "%s+", ""))
        if line ~= "" then
            local mode = "y"
            local expr = line
            if string.sub(line, 1, 2) == "r=" then mode = "r" expr = string.sub(line, 3)
            elseif string.sub(line, 1, 2) == "x=" then mode = "x" expr = string.sub(line, 3)
            elseif string.sub(line, 1, 2) == "y=" then mode = "y" expr = string.sub(line, 3) end
            
            expr = string.gsub(expr, "(%d)([%a%(])", "%1*%2")
            expr = string.gsub(expr, "^%-([%a%(])", "-1*%1")
            expr = string.gsub(expr, "([%+%-%*%/%%^%(])%-([%a%(])", "%1-1*%2")
            local env = setmetatable({}, {__index = math})
            
            if mode == "r" then
                local func = loadstring("return function(theta, i) return " .. expr .. " end")
                if func then
                    local success, generated = pcall(func)
                    if success and type(generated) == "function" then
                        setfenv(generated, env)
                        for i = 1, totalObjects do
                            local theta = ((i - 1) / totalObjects) * (math.pi * 2)
                            env.theta = theta
                            local success2, radius = pcall(generated, theta, i)
                            if success2 and type(radius) == "number" then
                                table.insert(cframes, baseCF * CFrame.new(math.cos(theta) * radius, math.sin(theta) * radius, 0))
                            end
                        end
                    end
                end
            elseif mode == "x" then
                local func = loadstring("return function(i) return " .. expr .. " end")
                if func then
                    local success, generated = pcall(func)
                    if success and type(generated) == "function" then
                        setfenv(generated, env)
                        for i = 1, totalObjects do
                            local success2, xVal = pcall(generated, i)
                            if success2 and type(xVal) == "number" then table.insert(cframes, baseCF * CFrame.new(xVal, (i - 1) * 4, 0)) end
                        end
                    end
                end
            elseif mode == "y" then
                local func = loadstring("return function(x, i) return " .. expr .. " end")
                if func then
                    local success, generated = pcall(func)
                    if success and type(generated) == "function" then
                        setfenv(generated, env)
                        for i = 1, totalObjects do
                            local xVal = (i - 1) * 4
                            local success2, yVal = pcall(generated, xVal, i)
                            if success2 and type(yVal) == "number" then table.insert(cframes, baseCF * CFrame.new(xVal, yVal, 0)) end
                        end
                    end
                end
            end
        end
    end
    if #cframes == 0 then return {baseCF} end
    return cframes
end

