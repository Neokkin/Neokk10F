local function updateLayoutSize()
    if ExpandBtn.Visible then return end
    local calculatedWidth = 20
    local activeColumns = 0
    for _, item in ipairs(clusters) do
        if item.Frame.Visible then
            calculatedWidth = calculatedWidth + item.Wide
            activeColumns = activeColumns + 1
        end
    end
    if activeColumns > 0 then
        calculatedWidth = calculatedWidth + ((activeColumns - 1) * 12)
    else
        calculatedWidth = 220
    end
    if calculatedWidth < 365 then calculatedWidth = 365 end 
    MainFrame.Size = UDim2.new(0, calculatedWidth, 0, 390)
    ScrollFrame.CanvasSize = UDim2.new(0, calculatedWidth - 20, 0, 320)
end

