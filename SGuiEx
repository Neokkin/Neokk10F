refreshPreviewVisual = function(forceResetState)
    if forceResetState then
        if previewConnection then previewConnection:Disconnect() end
        if previewModel then previewModel:Destroy() previewModel = nil end
    else
        currentState.previewActive = not currentState.previewActive
    end
    ShowBtn.Text = currentState.previewActive and "Hide Prev." or "Preview (P)"
    if not currentState.previewActive then if previewConnection then previewConnection:Disconnect() end if previewModel then previewModel:Destroy() previewModel = nil end return end
    
    local buildsFolder = ReplicatedStorage:FindFirstChild("Builds")
    local targetTemplate = buildsFolder and buildsFolder:FindFirstChild(currentState.buildName)
    if not targetTemplate then currentState.previewActive = false ShowBtn.Text = "Preview (P)" return end
    
    if currentState.equationBuildEnabled then
        previewModel = Instance.new("Model") previewModel.Name = "Local_EquationPreview"
        local cframes = getEquationCFrames()
        for i = 1, #cframes do
            local clone = targetTemplate:Clone()
            for _, item in ipairs(clone:GetDescendants()) do if item:IsA("BasePart") then item.Anchored = true item.CanCollide = false item.CastShadow = false item.Transparency = 0.5 end end
            if clone:IsA("Model") then clone:PivotTo(cframes[i]) else clone.CFrame = cframes[i] end
            clone.Parent = previewModel
        end
        previewModel.Parent = workspace
    else
        previewModel = targetTemplate:Clone() previewModel.Name = "Local_BuildPreview"
        for _, item in ipairs(previewModel:GetDescendants()) do if item:IsA("BasePart") then item.Anchored = true item.CanCollide = false item.CastShadow = false item.Transparency = 0.4 end end
        previewModel.Parent = workspace
    end
    
    if previewConnection then previewConnection:Disconnect() end
    previewConnection = RunService.RenderStepped:Connect(function()
        if not currentState.previewActive or not previewModel or not previewModel:IsDescendantOf(workspace) then return end
        if currentState.equationBuildEnabled then
            local cframes = getEquationCFrames() local children = previewModel:GetChildren()
            if #cframes ~= #children then task.spawn(function() refreshPreviewVisual(true) end) return end
            for idx, cf in ipairs(cframes) do local child = children[idx] if child then if child:IsA("Model") then child:PivotTo(cf) else child.CFrame = cf end end end
        else
            previewModel:PivotTo(getTargetCFrame())
        end
    end)
end

