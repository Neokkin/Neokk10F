local function executeBuild()
    local Remote = ReplicatedStorage:FindFirstChild("PlaceBuild")
    if not Remote then return end
    
    if currentState.equationBuildEnabled then
        local targetCFrames = getEquationCFrames()
        for _, cf in ipairs(targetCFrames) do
            task.spawn(function() Remote:InvokeServer(currentState.buildName, cf) end)
        end
    else
        local buildCF = getTargetCFrame() 
        for i = 1, currentState.multi do
            task.spawn(function() Remote:InvokeServer(currentState.buildName, buildCF) end)
        end
    end
end

