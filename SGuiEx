-- // --- [SECTION: ADVANCED 3D MATHEMATICAL PARSER] ---
local function snap(value, step) if step == 0 then return value end return math.round(value / step) * step end

-- Edge Snapping Logic Module
local function checkEdgeSnap(targetCFrame)
    if not currentState.snapToEdges then return targetCFrame end
    local origin = targetCFrame.Position
    local directions = {
        Vector3.new(0, -10, 0), Vector3.new(0, 10, 0),
        Vector3.new(-10, 0, 0), Vector3.new(10, 0, 0),
        Vector3.new(0, 0, -10), Vector3.new(0, 0, 10)
    }
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local filterList = {player.Character, previewModel}
    if airwalkPart then table.insert(filterList, airwalkPart) end
    raycastParams.FilterDescendantsInstances = filterList

    for _, dir in ipairs(directions) do
        local result = workspace:Raycast(origin, dir, raycastParams)
        if result and result.Instance and not result.Instance:IsDescendantOf(player.Character) then
            local p = result.Position
            return CFrame.new(p) * targetCFrame.Rotation
        end
    end
    return targetCFrame
end

local function getTargetCFrame()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return CFrame.new() end
    local root = player.Character.HumanoidRootPart
    local baseCFrame = CFrame.new()

    -- Character Front vs Camera Front Origin Processing Vector
    if currentState.originOrientation == "Char" then
        baseCFrame = root.CFrame * CFrame.new(0, 0, -20)
    else
        local cam = workspace.CurrentCamera
        if cam then
            local lookDist = cam.CFrame.LookVector * 20
            baseCFrame = CFrame.new(root.Position + lookDist, root.Position + lookDist + cam.CFrame.LookVector)
        else
            baseCFrame = root.CFrame * CFrame.new(0, 0, -20)
        end
    end

    if currentState.yLockEnabled then 
        baseCFrame = CFrame.new(baseCFrame.X, currentState.lockedYValue, baseCFrame.Z) * baseCFrame.Rotation 
    else 
        currentState.lockedYValue = baseCFrame.Y 
    end

    local finalX = snap(currentState.posX, currentState.snapGrid)
    local finalY = snap(currentState.posY, currentState.snapGrid)
    local finalZ = snap(currentState.posZ, currentState.snapGrid)
    local finalRotX = snap(currentState.rotX, currentState.snapAngle)
    local finalRotY = snap(currentState.rotY, currentState.snapAngle)
    local finalRotZ = snap(currentState.rotZ, currentState.snapAngle)
    
    local offsetCF = baseCFrame * CFrame.new(finalX, finalY, finalZ) * CFrame.Angles(math.rad(finalRotX), math.rad(finalRotY), math.rad(finalRotZ))
    return checkEdgeSnap(offsetCF)
end

local function getEquationCFrames()
    local cframes = {}
    local totalObjects = math.max(1, currentState.multi)
    local baseCF = getTargetCFrame()
    
    -- Format and normalize safe mathematical environment inputs
    local innerCode = [[
        local math = math
        local sin, cos, tan, rad, deg = math.sin, math.cos, math.tan, math.rad, math.deg
        local pi, sqrt, abs, exp, log = math.pi, math.sqrt, math.abs, math.exp, math.log
        local sinh, cosh, tanh, asin, acos, atan = math.sinh, math.cosh, math.tanh, math.asin, math.acos, math.atan
        return function(t, i, total)
            local x, y, z = 0, 0, 0
            local theta = t * pi * 2
            local phi = t * pi
            ]] .. currentState.equationText .. [[
            return x, y, z
        end
    ]]
    
    local compiled, err = loadstring(innerCode)
    if not compiled then return {baseCF} end
    
    local success, runFunc = pcall(compiled)
    if not success or type(runFunc) ~= "function" then return {baseCF} end
    
    for i = 1, totalObjects do
        local t = (totalObjects > 1) and ((i - 1) / (totalObjects - 1)) or 0
        local sX, sY, sZ = 0, 0, 0
        local ok, cx, cy, cz = pcall(runFunc, t, i, totalObjects)
        if ok and type(cx) == "number" and type(cy) == "number" and type(cz) == "number" then
            sX, sY, sZ = cx * currentState.spacing, cy * currentState.spacing, cz * currentState.spacing
        end
        
        local elementCFrame
        if currentState.affectMode == "All" then
            -- Global Structural Matrix Pivot Mode
            elementCFrame = baseCF * CFrame.new(sX, sY, sZ)
        else
            -- Component-Local Space Vector Transformation Mode
            elementCFrame = baseCF * CFrame.new(sX, sY, sZ) * CFrame.Angles(math.rad(currentState.rotX), math.rad(currentState.rotY), math.rad(currentState.rotZ))
        end
        table.insert(cframes, checkEdgeSnap(elementCFrame))
    end
    
    if #cframes == 0 then return {baseCF} end
    return cframes
end

local function executeBuild()
    local Remote = ReplicatedStorage:FindFirstChild("PlaceBuild")
    if not Remote then return end
    if currentState.equationBuildEnabled then
        local targetCFrames = getEquationCFrames()
        for _, cf in ipairs(targetCFrames) do task.spawn(function() Remote:InvokeServer(currentState.buildName, cf) end) end
    else
        local buildCF = getTargetCFrame() 
        for i = 1, currentState.multi do task.spawn(function() Remote:InvokeServer(currentState.buildName, buildCF) end) end
    end
end

