        {"🪃 Henneberg Minimal Hook", "local u = -1.5 + (i / n) * 3\nlocal v = (i % 12) / 12 * pi\nx = 2 * sinh(u) * cos(v) - (2/3) * sinh(3*u) * cos(3*v)\nz = 2 * sinh(u) * sin(v) + (2/3) * sinh(3*u) * sin(3*v)\ny = 2 * cosh(2*u) * cos(2*v)"},
        {"🛸 Catalan Minimal Surface", "local u = -2 + (i / n) * 4\nlocal v = (i % 12) / 12 * 4 * pi\nx = 5 * (u - sin(u) * cosh(v))\nz = 5 * (1 - cos(u) * cosh(v))\ny = 20 * sin(u / 2) * sinh(v / 2)"},
        {"🪱 Kuen Surface Bulb", "local u = -4 + (i / n) * 8\nlocal v = 0.05 + (i % 12) / 12 * (pi - 0.1)\nlocal den = 1 + u*u * sin(v)*sin(v)\nx = 2 * (cos(u) + u * sin(u)) * sin(v) / den * 7\nz = 2 * (sin(u) - u * cos(u)) * sin(v) / den * 7\ny = (log(tan(v / 2)) + 2 * cos(v) / den) * 4"},
        {"🐚 Sievert Complex Shell", "local u = -1.5 + (i / n) * 3\nlocal v = 0.05 + (i % 12) / 12 * (pi - 0.1)\nlocal r = 8 / (1 + sin(v)*sin(v) * sinh(u)*sinh(u))\nx = r * sin(v) * (cosh(u) * cos(u) + sinh(u) * sin(u) * sin(v))\nz = r * sin(v) * (cosh(u) * sin(u) - sinh(u) * cos(u) * sin(v))\ny = r * (cos(v) * cosh(u) + 0.5 * sin(2*v) * sinh(u))"},
