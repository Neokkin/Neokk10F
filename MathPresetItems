        {"🧽 Gyroid Solid Lattice Cube", "local side = floor(n^(1/3))\nlocal dx = (i - 1) % side local dy = floor(((i - 1) % (side^2)) / side) local dz = floor((i - 1) / (side^2))\nlocal u = (dx / (side-1)) * 4 * pi local v = (dy / (side-1)) * 4 * pi local w = (dz / (side-1)) * 4 * pi\nif abs(sin(u)*cos(v) + sin(v)*cos(w) + sin(w)*cos(u)) > 0.4 then\n    x = (u-2*pi)*3 z = (w-2*pi)*3 y = (v-2*pi)*3\nelse x = -500 y = -500 z = -500 end"},
