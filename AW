-- Engine Physics Connection Hook
trackConnection(RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not rootPart or not humanoid then return end

    -- 1. Airwalk Platform Execution Module
    if airwalkEnabled then
        local currentFeetY = rootPart.Position.Y - 3.5
        if airwalkY == 0 then airwalkY = currentFeetY end
        
        local speed = 30
        if manualMovingUp then
            local deltaMove = speed * dt 
            airwalkY = airwalkY + deltaMove 
            rootPart.CFrame = rootPart.CFrame + Vector3.new(0, deltaMove, 0)
        elseif manualMovingDown then
            local deltaMove = speed * dt 
            airwalkY = airwalkY - deltaMove 
            rootPart.CFrame = rootPart.CFrame + Vector3.new(0, -deltaMove, 0)
        elseif humanoid.Jump or UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            airwalkY = airwalkY + (humanoid.JumpPower * dt)
        elseif not noclipEnabled then
            -- CRITICAL FIX: Raycasting optimization excludes the airwalk platform itself to completely stop sinking
            local rayParams = RaycastParams.new()
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            rayParams.FilterDescendantsInstances = {char, airwalkPart}
            
            local groundRay = workspace:Raycast(rootPart.Position, Vector3.new(0, -5, 0), rayParams)
            if groundRay and humanoid.FloorMaterial ~= Enum.Material.Air then
                airwalkY = groundRay.Position.Y
            end
            
            -- Strict vertical lock stabilization clamping
            if not manualMovingUp and not manualMovingDown and humanoid.MoveDirection.Magnitude == 0 then
                rootPart.Velocity = Vector3.new(rootPart.Velocity.X, 0, rootPart.Velocity.Z)
                rootPart.CFrame = CFrame.new(rootPart.Position.X, airwalkY + 3.5, rootPart.Position.Z) * rootPart.CFrame.Rotation
            end
        end
        
        if noclipEnabled then
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, 0, rootPart.Velocity.Z)
            rootPart.CFrame = CFrame.new(rootPart.Position.X, airwalkY + 3.5, rootPart.Position.Z) * rootPart.CFrame.Rotation
        end
        
        if not airwalkPart or not airwalkPart.Parent then
            airwalkPart = Instance.new("Part") 
            airwalkPart.Size = Vector3.new(16, 0.5, 16) 
            airwalkPart.Transparency = 1 
            airwalkPart.Anchored = true 
            airwalkPart.CanCollide = true 
            airwalkPart.Parent = workspace
        end
        airwalkPart.CFrame = CFrame.new(rootPart.Position.X, airwalkY, rootPart.Position.Z)
    end

    -- 2. Frame-Perfect TP Walk Core Module
    if tpWalkEnabled and humanoid.MoveDirection.Magnitude > 0 then
        local moveDir = humanoid.MoveDirection
        rootPart.CFrame = rootPart.CFrame + (moveDir * tpwSpeed)
    end
end))

local physicsHookName = RunService:FindFirstChild("Stepped") and "Stepped" or "PreSimulation"
