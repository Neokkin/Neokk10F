trackConnection(BigTpDownBtn.MouseButton1Click:Connect(function() instantaneousVerticalTp(-yTpDiff) end))

-- // --- [HOLD INTERACTION & SWAPPER ENGINES] ---
local function setupSwapperSystem(btn, box, choices, updateCallback)
    local currentIndex = 1
    local holdCancelled = false
    local connectionBegan, connectionEnded
    
    connectionBegan = btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holdCancelled = false
            task.delay(0.7, function()
                if not holdCancelled and scriptActive then
                    btn.Visible = false
                    box.Visible = true
                    box:CaptureFocus()
                end
            end)
        end
    end)
    
    connectionEnded = btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holdCancelled = true
        end
    end)
    
    local clickConn = btn.MouseButton1Click:Connect(function()
        if box.Visible then return end
        currentIndex = (currentIndex % #choices) + 1
        local val = choices[currentIndex]
        btn.Text = tostring(val)
        updateCallback(val)
    end)
    
    local focusConn = box.FocusLost:Connect(function(enterPressed)
        local num = tonumber(box.Text)
        if num then
            btn.Text = tostring(num)
            updateCallback(num)
        end
        box.Visible = false
        btn.Visible = true
    end)
    
    table.insert(activeConnections, connectionBegan)
    table.insert(activeConnections, connectionEnded)
    table.insert(activeConnections, clickConn)
    table.insert(activeConnections, focusConn)
end

setupSwapperSystem(TpwSwapperBtn, TpwBox, tpwChoices, function(newVal) tpwSpeed = newVal end)
setupSwapperSystem(YTpSwapperBtn, YTpBox, yTpChoices, function(newVal) yTpDiff = newVal end)

-- // --- [GLOBAL DRAG COMPONENT ENGINE] ---
local dragging, dragInput, dragStart, startPos
trackConnection(DragHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true 
        dragStart = input.Position 
        startPos = AirwalkContainer.Position
        trackConnection(input.Changed:Connect(function() 
            if input.UserInputState == Enum.UserInputState.End then dragging = false end 
        end))
    end
end))

trackConnection(DragHandle.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then 
        dragInput = input 
    end
end))

trackConnection(UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        AirwalkContainer.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end))

-- // --- [CLEANUP DESTRUCTOR EXECUTIONS] ---
local function runFullDestructionCleanup()
    scriptActive = false
    if descAddedConn then descAddedConn:Disconnect() end
    for _, conn in ipairs(activeConnections) do 
        if conn.Connected then conn:Disconnect() end 
    end
    if airwalkPart then airwalkPart:Destroy() end
    setCharacterCollision(true)
    ScreenGui:Destroy()
end

trackConnection(CloseBtn.MouseButton1Click:Connect(runFullDestructionCleanup))
