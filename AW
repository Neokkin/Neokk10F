-- High-Performance Noclip Part Caching System
local noclipParts = {}
local descAddedConn = nil

local function cacheCharacterParts(char)
    table.clear(noclipParts)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then table.insert(noclipParts, part) end
    end
    if descAddedConn then descAddedConn:Disconnect() end
    descAddedConn = char.DescendantAdded:Connect(function(desc)
        if desc:IsA("BasePart") then table.insert(noclipParts, desc) end
    end)
end

trackConnection(player.CharacterAdded:Connect(cacheCharacterParts))
if player.Character then cacheCharacterParts(player.Character) end

