local function instantaneousVerticalTp(yOffset)
    local char = player.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = rootPart.CFrame + Vector3.new(0, yOffset, 0)
        if airwalkEnabled then
            airwalkY = airwalkY + yOffset
        end
    end
end

