local function Create(className, properties)
	local instance = Instance.new(className)
	for k, v in pairs(properties) do
		instance[k] = v
	end
	return instance
end

local function FireBuildRemote(bName, cframe)
	local placeBuild = ReplicatedStorage:FindFirstChild("PlaceBuild")
	if placeBuild and placeBuild:IsA("RemoteFunction") then
		task.spawn(function()
			placeBuild:InvokeServer(bName, cframe)
		end)
	end
end

local function HookLongHold(button, action, stopAction)
	local holding = false
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			holding = true
			task.spawn(function()
				action()
				task.wait(0.4)
				while holding do
					action()
					task.wait(0.02)
				end
			end)
		end
	end)
	
	local function endHold()
		if holding then
			holding = false
			if stopAction then stopAction() end
		end
	end
	button.InputEnded:Connect(endHold)
	button.FocusLost:Connect(endHold)
end

