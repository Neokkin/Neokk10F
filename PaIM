-- MATH EQUATION INTERPRETER & EXECUTION
-- ==========================================
local function BuildEquationExecution()
	local formulaStr = MathInput.Text
	if formulaStr == "" then return end
	
	-- Strict Sanitize Check for execution safety injection
	formulaStr = formulaStr:gsub(" ", "")
	
	-- Simple dynamic solver step projection loop for 10 sequential iterations
	for step = 1, 10 do
		local x = step * 3
		-- Basic programmatic processing translation framework matching simple functions: y = x^2 / 10
		local processedStr = formulaStr:gsub("x%^2", tostring(x * x)):gsub("x", tostring(x))
		
		local success, result = pcall(function()
			-- Handles simple arithmetic configurations natively without loadstring environments
			local cleanStr = processedStr:gsub("y=", "")
			local divSplit = cleanStr:split("/")
			if #divSplit == 2 then
				return tonumber(divSplit[1]) / tonumber(divSplit[2])
			end
			return tonumber(cleanStr) or 0
		end)
		
		if success and result then
			local calculatedY = result
			local calculatedCF = GetTargetCenter() * CFrame.new(x, calculatedY, 0)
			
			for matName, active in pairs(State.SelectedMaterials) do
				if active then
					for i = 1, State.Count do
						-- Stagger sequential steps via count multiplier variables
						local passCF = calculatedCF * CFrame.new(0, 0, -(i - 1) * 4)
						FireBuildRemote(matName, passCF)
					end
				end
			end
		end
	end
end

BuildMathBtn.MouseButton1Click:Connect(BuildEquationExecution)

