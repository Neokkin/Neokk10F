local function rebuildMaterialGrid()
	for _, child in ipairs(MatScroll:GetChildren()) do
		if not child:IsA("UIGridLayout") and not child:IsA("UIListLayout") then child:Destroy() end
	end
	
	local currentY = 0
	for catName, items in pairs(MaterialsManifest) do
		table.sort(items)
		local catLabel = Instance.new("TextLabel")
		catLabel.Size = UDim2.new(1, -10, 0, 20)
		catLabel.Position = UDim2.fromOffset(0, currentY)
		catLabel.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
		catLabel.Text = "  " .. catName
		catLabel.TextColor3 = Color3.fromRGB(220, 180, 100)
		catLabel.TextXAlignment = Enum.TextAlignment.Left
		catLabel.Font = Enum.Font.SourceSansBold
		catLabel.TextSize = 13
		catLabel.Parent = MatScroll
		
		currentY = currentY + 24
		
		for _, item in ipairs(items) do
			local isSelected = MultiSelectedMaterials[item] or (State.SelectedMaterial == item)
			local itemColor = isSelected and Color3.fromRGB(45, 110, 145) or Color3.fromRGB(55, 55, 60)
			
			local ibtn = createButton("Mat_" .. item, item, UDim2.fromOffset(5, currentY), UDim2.new(1, -15, 0, 22), MatScroll, itemColor)
			ibtn.TextXAlignment = Enum.TextAlignment.Left
			ibtn.Text = "   " .. item
			
			ibtn.MouseButton1Click:Connect(function()
				if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl) then
					MultiSelectedMaterials[item] = not MultiSelectedMaterials[item]
				else
					table.clear(MultiSelectedMaterials)
					State.SelectedMaterial = item
				end
				rebuildMaterialGrid()
			end)
			
			currentY = currentY + 24
		end
	end
	MatScroll.CanvasSize = UDim2.fromOffset(0, currentY + 10)
end
