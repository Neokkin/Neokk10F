local function CreateInputDropdownCircle(parent, defaultText, layoutOrder, onSelection)
	local container = Create("Frame", {
		Size = UDim2.new(0, 44, 0, 44),
		BackgroundTransparency = 1,
		LayoutOrder = layoutOrder,
		Parent = parent
	})
	
	local textBox = Create("TextBox", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundColor3 = Color3.fromRGB(35, 35, 40),
		BackgroundTransparency = 0.15,
		Text = defaultText,
		TextColor3 = Color3.fromRGB(240, 240, 240),
		Font = Enum.Font.SourceSansBold,
		TextSize = 11,
		ClearTextOnFocus = false,
		Parent = container
	})
	Create("UICorner", { CornerRadius = UDim.new(0, 22), Parent = textBox })
	
	local dropFrame = Create("Frame", {
		Size = UDim2.new(0, 50, 0, 120),
		Position = UDim2.new(0, -3, 0, -125),
		BackgroundColor3 = Color3.fromRGB(25, 25, 30),
		Visible = false,
		ZIndex = 5,
		Parent = container
	})
	Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = dropFrame })
	Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = dropFrame })
	
	textBox.Focused:Connect(function() dropFrame.Visible = true end)
	textBox.FocusLost:Connect(function()
		task.wait(0.2)
		dropFrame.Visible = false
		local val = tonumber(textBox.Text)
		if val then onSelection(val) end
	end)
	
	return textBox, dropFrame
end

