local function UpdateAirWalk()
	if State.AirWalkActive then
		if not State.AirWalkPlatform or not State.AirWalkPlatform.Parent then
			State.AirWalkPlatform = Create("Part", {
				Name = "AirWalkAnchor",
				Size = Vector3.new(6, 0.5, 6),
				Transparency = 1,
				Anchored = true,
				CanCollide = true,
				Position = Vector3.new(0,0,0)
			})
		end
		local character = LocalPlayer.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if root then
			State.AirWalkPlatform.Position = root.Position + Vector3.new(0, -2.75, 0)
			State.AirWalkPlatform.Parent = workspace
		end
		AirWalkToggle.Text = "AirWalk: ON"
		AirWalkControls.Visible = true
	else
		if State.AirWalkPlatform then
			State.AirWalkPlatform:Destroy()
			State.AirWalkPlatform = nil
		end
		AirWalkToggle.Text = "AirWalk: OFF"
		AirWalkControls.Visible = false
	end
end

