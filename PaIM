-- ==========================================
-- WORLD PREVIEW & GIZMO PIPELINES
-- ==========================================
local function ClearLocalVisuals()
	for _, m in pairs(State.PreviewModels) do m:Destroy() end
	for _, g in pairs(State.GizmoParts) do g:Destroy() end
	State.PreviewModels = {}
	State.GizmoParts = {}
end

local function GetTargetCenter()
	local camera = workspace.CurrentCamera
	local character = LocalPlayer.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	
	local baseCF = CFrame.new()
	if State.MobilityMode == "Cam" and camera then
		baseCF = camera.CFrame
	elseif root then
		baseCF = root.CFrame
	end
	
	-- Resolve local translation vectors
	local workingCF = baseCF * CFrame.new(State.OffsetPosition)
	return workingCF * CFrame.Angles(math.rad(State.OffsetRotation.X), math.rad(State.OffsetRotation.Y), math.rad(State.OffsetRotation.Z))
end

local function RenderVisualEngine()
	ClearLocalVisuals()
	if not State.ShowPreview then return end
	
	local centerCF = GetTargetCenter()
	local sourceStorage = ReplicatedStorage:FindFirstChild("Builds")
	
	-- Generate locally simulated projections
	for matName, active in pairs(State.SelectedMaterials) do
		if active and sourceStorage then
			local template = sourceStorage:FindFirstChild(matName)
			if template then
				local clone = template:Clone()
				if clone:IsA("Model") then
					clone:SetPrimaryPartCFrame(centerCF)
					for _, p in pairs(clone:GetDescendants()) do
						if p:IsA("BasePart") then
							p.Transparency = 0.5
							p.CanCollide = false
							p.Anchored = true
						end
					end
					clone.Parent = workspace
					table.insert(State.PreviewModels, clone)
				end
			end
		end
	end
	
	if State.ShowGizmos then
		local axes = {
			{Vector3.new(2, 0, 0), Color3.fromRGB(255, 50, 50)},   -- X: Red
			{Vector3.new(0, 2, 0), Color3.fromRGB(50, 255, 50)},   -- Y: Green
			{Vector3.new(0, 0, 2), Color3.fromRGB(50, 50, 255)}    -- Z: Blue
		}
		for _, data in pairs(axes) do
			local gizmo = Create("Part", {
				Size = data[1] + Vector3.new(0.2, 0.2, 0.2),
				Color = data[2],
				Transparency = 0.4,
				Anchored = true,
				CanCollide = false,
				CFrame = centerCF * CFrame.new(data[1]/2),
				Parent = workspace
			})
			table.insert(State.GizmoParts, gizmo)
		end
	end
end

-- Hook updates into rendering ticks safely
RunService.RenderStepped:Connect(function()
	if State.ShowPreview then
		local centerCF = GetTargetCenter()
		for _, m in pairs(State.PreviewModels) do
			if m.PrimaryPart then m:SetPrimaryPartCFrame(centerCF) end
		end
		-- Re-render anchors cleanly if structural transforms update
		if #State.GizmoParts > 0 then RenderVisualEngine() end
	end
end)

