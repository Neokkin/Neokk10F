local function clearLocalGizmos()
	for _, part in ipairs(GizmoParts) do part:Destroy() end
	table.clear(GizmoParts)
end

local function drawAxisGizmo(centerCFrame)
	clearLocalGizmos()
	if not State.GizmosActive or not State.PreviewActive then return end
	
	local axes = {
		{Vector3.new(3, 0.1, 0.1), Color3.fromRGB(255, 50, 50)}, -- X Axis line configuration
		{Vector3.new(0.1, 3, 0.1), Color3.fromRGB(50, 255, 50)}, -- Y Axis line configuration
		{Vector3.new(0.1, 0.1, 3), Color3.fromRGB(50, 50, 255)}  -- Z Axis line configuration
	}
	
	for _, info in ipairs(axes) do
		local p = Instance.new("Part")
		p.Size = info[1]
		p.Color = info[2]
		p.Material = Enum.Material.Neon
		p.Anchored = true
		p.CanCollide = false
		p.Transparency = 0.2
		
		-- Center transformation mappings
		if info[1].X > 0.1 then
			p.CFrame = centerCFrame * CFrame.new(1.5, 0, 0)
		elseif info[1].Y > 0.1 then
			p.CFrame = centerCFrame * CFrame.new(0, 1.5, 0)
		else
			p.CFrame = centerCFrame * CFrame.new(0, 0, -1.5)
		end
		
		p.Parent = workspace
		table.insert(GizmoParts, p)
	end
end

local function cleanActivePreview()
	if ActivePreviewModel then
		ActivePreviewModel:Destroy()
		ActivePreviewModel = nil
	end
	clearLocalGizmos()
end

local function updatePreviewEngine()
	if not State.PreviewActive then
		cleanActivePreview()
		return
	end
	
	local targetModel = BuildsFolder:FindFirstChild(State.SelectedMaterial)
	if not targetModel then return end
	
	if not ActivePreviewModel or ActivePreviewModel.Name ~= State.SelectedMaterial then
		if ActivePreviewModel then ActivePreviewModel:Destroy() end
		ActivePreviewModel = targetModel:Clone()
		ActivePreviewModel.Parent = workspace
		
		for _, part in ipairs(ActivePreviewModel:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Transparency = 0.5
				part.CanCollide = false
				part.Anchored = true
			end
		end
	end
	
	local trackingBase = Vector3.zero
	if State.MobilityMode == "Cam" then
		trackingBase = Camera.CFrame.Position + (Camera.CFrame.LookVector * 15)
	else
		local char = LocalPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if hrp then
			trackingBase = hrp.Position + (hrp.CFrame.LookVector * 15)
		end
	end
	
	local finalPosition = trackingBase + State.BuildCenterOffset
	local finalCFrame = CFrame.new(finalPosition) * CFrame.fromEulerAnglesXYZ(
		math.rad(State.CurrentRotation.X),
		math.rad(State.CurrentRotation.Y),
		math.rad(State.CurrentRotation.Z)
	)
	
	if ActivePreviewModel:IsA("Model") then
		ActivePreviewModel:PivotTo(finalCFrame)
	elseif ActivePreviewModel:IsA("BasePart") then
		ActivePreviewModel.CFrame = finalCFrame
	end
	
	if State.GizmosActive then
		drawAxisGizmo(finalCFrame)
	else
		clearLocalGizmos()
	end
end

RunService.RenderStepped:Connect(updatePreviewEngine)

