local function PopulateDropdownOptions(frame, box, options, stateKey)
	for i, opt in ipairs(options) do
		local optBtn = Create("TextButton", {
			Size = UDim2.new(1, 0, 0, 22),
			BackgroundColor3 = Color3.fromRGB(40, 40, 45),
			Text = tostring(opt),
			TextColor3 = Color3.fromRGB(230, 230, 230),
			Font = Enum.Font.SourceSans,
			TextSize = 11,
			ZIndex = 6,
			LayoutOrder = i,
			Parent = frame
		})
		optBtn.MouseButton1Click:Connect(function()
			State[stateKey] = opt
			box.Text = (stateKey == "Count") and ("Cnt: " .. opt) or (string.sub(stateKey, 1, 1) .. ": " .. opt)
			frame.Visible = false
			if State.ShowPreview then RenderVisualEngine() end
		end)
	end
end
