local function syncAirWalkPlatform()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	if State.AirWalkActive then
		if not AirWalkPlatform then
			AirWalkPlatform = Instance.new("Part")
			AirWalkPlatform.Name = "LocalAirWalkAnchor"
			AirWalkPlatform.Size = Vector3.new(6, 1, 6)
			AirWalkPlatform.Transparency = 1
			AirWalkPlatform.Anchored = true
			AirWalkPlatform.CanCollide = true
			AirWalkPlatform.Parent = workspace
		end
		AirWalkPlatform.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - 3.5, hrp.Position.Z)
	else
		if AirWalkPlatform then
			AirWalkPlatform:Destroy()
			AirWalkPlatform = nil
		end
	end
end

local function offsetAirWalk(amount)
	if AirWalkPlatform and State.AirWalkActive then
		local char = LocalPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if hrp then
			AirWalkPlatform.CFrame = AirWalkPlatform.CFrame + Vector3.new(0, amount, 0)
			hrp.CFrame = hrp.CFrame + Vector3.new(0, amount, 0)
		end
	end
end

