-- ==========================================
-- VISUALIZATIONS & POSITION SYNCHRONIZER
-- ==========================================
local function GetTargetCenter()
	local camera = workspace.CurrentCamera
	local character = LocalPlayer.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local baseCF = CFrame.new()
	
	if State.MobilityMode == "Cam" and camera then
		baseCF = camera.CFrame
	elseif root then
		baseCF = root.CFrame
	end
	
	local workingCF = baseCF * CFrame.new(State.OffsetPosition)
	return workingCF * CFrame.Angles(math.rad(State.OffsetRotation.X), math.rad(State.OffsetRotation.Y), math.rad(State.OffsetRotation.Z))
end

local function CleanVisualProjections()
	for _, m in pairs(State.PreviewModels) do m:Destroy() end
	for _, g in pairs(State.GizmoParts) do g:Destroy() end
	State.PreviewModels = {}
	State.GizmoParts = {}
end

local function RenderVisualEngine()
	CleanVisualProjections()
	if not State.ShowPreview then return end
	
	local centerCF = GetTargetCenter()
	local sourceStorage = ReplicatedStorage:FindFirstChild("Builds")
	
	for matName, active in pairs(State.SelectedMaterials) do
		if active and sourceStorage then
			local targetModel = sourceStorage:FindFirstChild(matName)
			if targetModel and targetModel:IsA("Model") then
				local clone = targetModel:Clone()
				clone:SetPrimaryPartCFrame(centerCF)
				for _, part in pairs(clone:GetDescendants()) do
					if part:IsA("BasePart") then
						part.Transparency = 0.5
						part.CanCollide = false
						part.Anchored = true
					end
				end
				clone.Parent = workspace
				table.insert(State.PreviewModels, clone)
			end
		end
	end
	
	if State.ShowGizmos then
		local directions = { Vector3.new(3, 0, 0), Vector3.new(0, 3, 0), Vector3.new(0, 0, 3) }
		local colors = { Color3.fromRGB(255, 60, 60), Color3.fromRGB(60, 255, 60), Color3.fromRGB(60, 60, 255) }
		
		for i = 1, 3 do
			local gizmo = Create("Part", {
				Size = directions[i] + Vector3.new(0.15, 0.15, 0.15),
				Color = colors[i],
				Transparency = 0.4,
				Anchored = true,
				CanCollide = false,
				CFrame = centerCF * CFrame.new(directions[i] / 2),
				Parent = workspace
			})
			table.insert(State.GizmoParts, gizmo)
		end
	end
end

RunService.RenderStepped:Connect(function()
	if State.ShowPreview then
		local centerCF = GetTargetCenter()
		for _, m in pairs(State.PreviewModels) do
			if m and m.Parent and m.PrimaryPart then m:SetPrimaryPartCFrame(centerCF) end
		end
		
		if State.ShowGizmos and #State.GizmoParts == 3 then
			local directions = { Vector3.new(3, 0, 0), Vector3.new(0, 3, 0), Vector3.new(0, 0, 3) }
			for i, part in ipairs(State.GizmoParts) do
				if part and part.Parent then
					part.CFrame = centerCF * CFrame.new(directions[i] / 2)
				end
			end
		end
	end
end)

