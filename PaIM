-- MATH ENGINE SOLVER EXECUTION
-- ==========================================
BuildMathBtn.MouseButton1Click:Connect(function()
	local input = MathInput.Text:gsub(" ", ""):gsub("y=", "")
	if input == "" then return end
	
	for elementX = -15, 15, 3 do
		local expression = input:gsub("x%^2", tostring(elementX * elementX)):gsub("x", tostring(elementX))
		local divisionSplit = expression:split("/")
		local computedY = 0
		
		if #divisionSplit == 2 then
			local num = tonumber(divisionSplit[1]) or 0
			local den = tonumber(divisionSplit[2]) or 1
			computedY = num / den
		else
			computedY = tonumber(expression) or 0
		end
		
		local resolvedCF = GetTargetCenter() * CFrame.new(elementX, computedY, 0)
		for matName, active in pairs(State.SelectedMaterials) do
			if active then
				for countTier = 1, State.Count do
					local sequenceCF = resolvedCF * CFrame.new(0, 0, -(countTier - 1) * 4)
					FireBuildRemote(matName, sequenceCF)
				end
			end
		end
	end
end)

