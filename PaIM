-- Long Hold Execution Helper Object Block
local function HookLongHold(button, action)
	local holding = false
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			holding = true
			task.spawn(function()
				action()
				task.wait(0.4)
				while holding do
					action()
					task.wait(0.08)
				end
			end)
		end
	end)
	local function stopHold() holding = false end
	button.InputEnded:Connect(stopHold)
	button.FocusLost:Connect(stopHold)
end

HookLongHold(AWUp, function() MoveAirWalk(0.5) end)
HookLongHold(AWDown, function() MoveAirWalk(-0.5) end)

