-- Execution Vectors processing routing
local function ApplyTransformation(axis, direction, isDownPart)
	local mult = direction * (isDownPart and -1 or 1)
	if State.CurrentMode == "Rotation" then
		local delta = State.RDifference * mult
		if axis == "X" then State.OffsetRotation = State.OffsetRotation + Vector3.new(delta, 0, 0)
		elseif axis == "Y" then State.OffsetRotation = State.OffsetRotation + Vector3.new(0, delta, 0)
		elseif axis == "Z" then State.OffsetRotation = State.OffsetRotation + Vector3.new(0, 0, delta) end
	else
		local delta = State.PDifference * mult
		if axis == "X" then State.OffsetPosition = State.OffsetPosition + Vector3.new(delta, 0, 0)
		elseif axis == "Y" then State.OffsetPosition = State.OffsetPosition + Vector3.new(0, delta, 0)
		elseif axis == "Z" then State.OffsetPosition = State.OffsetPosition + Vector3.new(0, 0, delta) end
	end
	RenderVisualEngine()
end

