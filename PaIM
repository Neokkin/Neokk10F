local function fireDeploymentRemote(material, targetCFrame)
	local payload = {
		[1] = material,
		[2] = targetCFrame
	}
	PlaceBuildRemote:InvokeServer(unpack(payload))
end

BuildEquationBtn.MouseButton1Click:Connect(function()
	local formula = EquationInput.Text
	if formula == "" then return end
	
	local trackingBase = Vector3.zero
	if State.MobilityMode == "Cam" then
		trackingBase = Camera.CFrame.Position + (Camera.CFrame.LookVector * 15)
	else
		local char = LocalPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if hrp then
			trackingBase = hrp.Position + (hrp.CFrame.LookVector * 15)
		end
	end
	
	local basePosition = trackingBase + State.BuildCenterOffset
	local baseRotation = CFrame.fromEulerAnglesXYZ(
		math.rad(State.CurrentRotation.X),
		math.rad(State.CurrentRotation.Y),
		math.rad(State.CurrentRotation.Z)
	)
	
	-- Spatial Sequence Generation Loop Configuration (Step limits range: -10 to 10 studs)
	for xStep = -10, 10, 2 do
		local solvedY = evaluateMathExpression(formula, xStep)
		local localOffsetVector = Vector3.new(xStep, solvedY, 0)
		local compiledCFrame = CFrame.new(basePosition + localOffsetVector) * baseRotation
		
		local pipelineMaterials = {}
		for mat, active in pairs(MultiSelectedMaterials) do
			if active then table.insert(pipelineMaterials, mat) end
		end
		if #pipelineMaterials == 0 then table.insert(pipelineMaterials, State.SelectedMaterial) end
		
		for _, activeMat in ipairs(pipelineMaterials) do
			for cycle = 1, State.Count do
				-- Step displacement loop sequence iteration shift multiplier
				local finalStagedCFrame = compiledCFrame * CFrame.new(0, 0, -(cycle - 1) * State.Pdifference)
				task.spawn(fireDeploymentRemote, activeMat, finalStagedCFrame)
			end
		end
	end
end)

