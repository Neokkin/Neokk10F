	State.AirWalkActive = not State.AirWalkActive
	if State.AirWalkActive then
		local character = LocalPlayer.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		State.AirWalkY = root and (root.Position.Y - 2.8) or 0
		AirWalkToggle.Text = "AirWalk: ON"
