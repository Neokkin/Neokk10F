local function runTransformationOffset(axis, directionalSign)
	local multiplier = State.Inverted and -1 or 1
	local increment = directionalSign * multiplier
	
	if State.Mode == "Rotation" then
		local step = State.Rdifference * increment
		if axis == "X" then
			State.CurrentRotation = State.CurrentRotation + Vector3.new(step, 0, 0)
		elseif axis == "Y" then
			State.CurrentRotation = State.CurrentRotation + Vector3.new(0, step, 0)
		elseif axis == "Z" then
			State.CurrentRotation = State.CurrentRotation + Vector3.new(0, 0, step)
		end
	else
		local step = State.Pdifference * increment
		if axis == "X" then
			State.BuildCenterOffset = State.BuildCenterOffset + Vector3.new(step, 0, 0)
		elseif axis == "Y" then
			State.BuildCenterOffset = State.BuildCenterOffset + Vector3.new(0, step, 0)
		elseif axis == "Z" then
			State.BuildCenterOffset = State.BuildCenterOffset + Vector3.new(0, 0, step)
		end
	end
end

