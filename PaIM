local function makeDropdownInput(index, defaultValue, listOptions, parent, stateKey)
	local base = createCircularBase("ClusterB_B", index, parent)
	
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(1, 0, 1, 0)
	box.BackgroundTransparency = 1
	box.Text = tostring(defaultValue)
	box.TextColor3 = Color3.fromRGB(255, 255, 255)
	box.Font = Enum.Font.SourceSansBold
	box.TextSize = 12
	box.TextAlignment = Enum.TextAlignment.Center
	box.Parent = base
	
	local menuFrame = Instance.new("Frame")
	menuFrame.Size = UDim2.fromOffset(50, #listOptions * 22)
	menuFrame.Position = UDim2.new(0, -2, 0, -#listOptions * 22 - 4)
	menuFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
	menuFrame.Visible = false
	menuFrame.ZIndex = 10
	menuFrame.Parent = base
	
	local listCorner = Instance.new("UICorner")
	listCorner.CornerRadius = UDim.new(0, 4)
	listCorner.Parent = menuFrame
	
	for oIdx, val in ipairs(listOptions) do
		local opt = createButton("Opt_" .. val, tostring(val), UDim2.fromOffset(2, (oIdx - 1) * 22 + 2), UDim2.fromOffset(46, 18), menuFrame, Color3.fromRGB(50, 50, 55))
		opt.TextSize = 11
		opt.ZIndex = 11
		opt.MouseButton1Click:Connect(function()
			box.Text = tostring(val)
			State[stateKey] = tonumber(val) or val
			menuFrame.Visible = false
		end)
	end
	
	base.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.TouchLongPress then
			menuFrame.Visible = not menuFrame.Visible
		end
	end)
	
	box.FocusLost:Connect(function()
		local num = tonumber(box.Text)
		if num then
			State[stateKey] = num
		else
			box.Text = tostring(State[stateKey])
		end
	end)
	
	return box
end

