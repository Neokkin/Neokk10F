local AirWalkVerticalSpeed = 25 
RunService.Heartbeat:Connect(function(dt)
	if State.AirWalkActive then
		local character = LocalPlayer.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if root then
			if not State.AirWalkPlatform or not State.AirWalkPlatform.Parent then
				State.AirWalkPlatform = Create("Part", {
					Name = "ActiveAirWalkAnchor",
					Size = Vector3.new(150, 1, 150), 
					Transparency = 0.75,
					Color = Color3.fromRGB(0, 130, 255),
					Material = Enum.Material.ForceField,
					Anchored = true,
					CanCollide = true,
					Parent = workspace
				})
			end
			
			if State.MovingUp then 
				State.AirWalkY = State.AirWalkY + (AirWalkVerticalSpeed * dt)
				root.CFrame = root.CFrame + Vector3.new(0, AirWalkVerticalSpeed * dt, 0)
			elseif State.MovingDown then 
				State.AirWalkY = State.AirWalkY - (AirWalkVerticalSpeed * dt)
				root.CFrame = root.CFrame - Vector3.new(0, AirWalkVerticalSpeed * dt, 0)
			end
			
			State.AirWalkPlatform.Position = Vector3.new(root.Position.X, State.AirWalkY, root.Position.Z)
		end
	else
		if State.AirWalkPlatform then
			State.AirWalkPlatform:Destroy()
			State.AirWalkPlatform = nil
		end
	end
end)

