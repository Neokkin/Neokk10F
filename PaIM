-- ==========================================
-- INTERACTIVE EXTENSIONS & DRAG ENGINE
-- ==========================================
local function SetupDraggableEngine(targetTextLabel, boundFrame)
	local dragging, dragInput, dragStart, startPos
	
	targetTextLabel.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = boundFrame.Position
			
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	targetTextLabel.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			local targetX = startPos.X.Offset + delta.X
			local targetY = startPos.Y.Offset + delta.Y
			
			-- Absolute screen boundaries injection
			local currentScreen = ScreenGui.AbsoluteSize
			local frameSize = boundFrame.AbsoluteSize
			
			local minX = 0
			local maxX = currentScreen.X - frameSize.X
			local minY = 0
			local maxY = currentScreen.Y - frameSize.Y
			
			-- Account for Scale positional variants
			local computedX = startPos.X.Scale * currentScreen.X + targetX
			local computedY = startPos.Y.Scale * currentScreen.Y + targetY
			
			computedX = math.clamp(computedX, minX, maxX)
			computedY = math.clamp(computedY, minY, maxY)
			
			boundFrame.Position = UDim2.new(0, computedX, 0, computedY)
		end
	end)
end
SetupDraggableEngine(TitleBar, MainFrame)

