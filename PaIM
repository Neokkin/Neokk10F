local function ExecuteOffsetModifier(axis, direction)
	if State.CurrentMode == "Rotation" then
		local val = State.RDifference * direction
		if axis == "X" then State.OffsetRotation = State.OffsetRotation + Vector3.new(val, 0, 0)
		elseif axis == "Y" then State.OffsetRotation = State.OffsetRotation + Vector3.new(0, val, 0)
		elseif axis == "Z" then State.OffsetRotation = State.OffsetRotation + Vector3.new(0, 0, val) end
	else
		local val = State.PDifference * direction
		if axis == "X" then State.OffsetPosition = State.OffsetPosition + Vector3.new(val, 0, 0)
		elseif axis == "Y" then State.OffsetPosition = State.OffsetPosition + Vector3.new(0, val, 0)
		elseif axis == "Z" then State.OffsetPosition = State.OffsetPosition + Vector3.new(0, 0, val) end
	end
	if State.ShowPreview then RenderVisualEngine() end
end

