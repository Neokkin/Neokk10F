--------------------------------------------------------------------------------
-- MATHEMATICAL EQUATION PARSER (Safe Client Evaluation)
--------------------------------------------------------------------------------
local function evaluateMathExpression(equationStr, xValue)
	local cleanExpr = equationStr:gsub("x", tostring(xValue))
	cleanExpr = cleanExpr:gsub("sin", "math.sin")
	cleanExpr = cleanExpr:gsub("cos", "math.cos")
	cleanExpr = cleanExpr:gsub("tan", "math.tan")
	cleanExpr = cleanExpr:gsub("pi", "math.pi")
	cleanExpr = cleanExpr:gsub("%^", "**")
	
	local func, err = loadstring("return " .. cleanExpr)
	if func then
		local status, result = pcall(func)
		if status then return result end
	end
	return 0
end

--------------------------------------------------------------------------------
-- SYSTEM HELPERS & CLEANUP
--------------------------------------------------------------------------------
local function getScreenBounds(guiObject)
	local screen = guiObject.Parent
	if screen:IsA("ScreenGui") then
		return screen.AbsoluteSize
	end
	return Camera.ViewportSize
end

local function makeDraggable(frame, handle)
	local dragging = false
	local dragInput, dragStart, startPos
	
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			local targetPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			
			-- Frame clamping to screen size boundaries
			local screenSize = getScreenBounds(frame)
			local clampedX = math.clamp(targetPos.X.Offset, 0, screenSize.X - frame.AbsoluteSize.X)
			local clampedY = math.clamp(targetPos.Y.Offset, 0, screenSize.Y - frame.AbsoluteSize.Y)
			
			frame.Position = UDim2.new(0, clampedX, 0, clampedY)
		end
	end)
end

local function setupLongHold(button, actionOnStep)
	local isHolding = false
	
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isHolding = true
			task.wait(0.4) -- Activation delay
			while isHolding do
				actionOnStep()
				task.wait(0.1) -- Tick rate
			end
		end
	end)
	
	local function endHold()
		isHolding = false
	end
	button.InputEnded:Connect(endHold)
	button.MouseLeave:Connect(endHold)
end

