local function SetupCategorizedGrid(categoryName, items, order)
	Create("TextLabel", {
		Size = UDim2.new(1, 0, 0, 20),
		BackgroundTransparency = 1,
		Text = "--- " .. categoryName .. " ---",
		TextColor3 = Color3.fromRGB(150, 150, 160),
		Font = Enum.Font.SourceSansBold,
		TextSize = 12,
		LayoutOrder = order * 2,
		Parent = MaterialScroll
	})
	
	local gridFrame = Create("Frame", {
		Size = UDim2.new(1, 0, 0, math.ceil(#items / 2) * 32),
		BackgroundTransparency = 1,
		LayoutOrder = order * 2 + 1,
		Parent = MaterialScroll
	})
	Create("UIGridLayout", {
		CellSize = UDim2.new(0, 144, 0, 28),
		CellPadding = UDim2.new(0, 8, 0, 4),
		SortOrder = Enum.SortOrder.Name,
		Parent = gridFrame
	})
	
	for _, name in ipairs(items) do
		local mBtn = Create("TextButton", {
			BackgroundColor3 = State.SelectedMaterials[name] and Color3.fromRGB(35, 95, 160) or Color3.fromRGB(42, 42, 48),
			Text = name,
			TextColor3 = State.SelectedMaterials[name] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(215, 215, 215),
			Font = Enum.Font.SourceSans,
			TextSize = 11,
			Parent = gridFrame
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = mBtn })
		
		mBtn.MouseButton1Click:Connect(function()
			State.SelectedMaterials[name] = not State.SelectedMaterials[name]
			mBtn.BackgroundColor3 = State.SelectedMaterials[name] and Color3.fromRGB(35, 95, 160) or Color3.fromRGB(42, 42, 48)
			mBtn.TextColor3 = State.SelectedMaterials[name] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(215, 215, 215)
			if State.ShowPreview then RenderVisualEngine() end
		end)
	end
end

